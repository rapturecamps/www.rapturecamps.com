---
/**
 * Displays a grid of related blog posts, used on:
 * - Camp pages (fetches by silo matching the country)
 * - Blog post pages (fetches by hub first, then silo fallback)
 *
 * Pass `posts` directly OR let the component fetch via `siloName`/`hubName`.
 */
import { sanityClient } from "@/lib/sanity";
import { BLOG_POSTS_BY_SILO, RELATED_BLOG_POSTS } from "@/lib/queries";

interface Props {
  posts?: any[];
  siloName?: string;
  hubName?: string;
  excludeId?: string;
  limit?: number;
  lang?: string;
  title?: string;
  description?: string;
  background?: "dark" | "dark-lighter";
}

const {
  posts: passedPosts,
  siloName,
  hubName,
  excludeId = "",
  limit = 4,
  lang = "en",
  title,
  description,
  background = "dark-lighter",
} = Astro.props;

const prefix = lang === "de" ? "/de" : "";

let posts = passedPosts || [];

if (!posts.length && hubName && siloName) {
  const result = await sanityClient.fetch(RELATED_BLOG_POSTS, {
    hubName,
    siloName,
    excludeId,
    lang,
    limit,
  });
  const byHub = result?.byHub || [];
  const bySilo = result?.bySilo || [];
  const seen = new Set(byHub.map((p: any) => p._id));
  posts = [...byHub];
  for (const p of bySilo) {
    if (posts.length >= limit) break;
    if (!seen.has(p._id)) posts.push(p);
  }
} else if (!posts.length && siloName) {
  posts = await sanityClient.fetch(BLOG_POSTS_BY_SILO, {
    siloName,
    lang,
    limit,
  });
}

if (!posts?.length) return;

const heading = title || (lang === "de" ? "Ähnliche Artikel" : "Related Articles");
const subtitle = description || (lang === "de" ? "Mehr lesen zu diesem Thema" : "More on this topic");

function formatDate(dateStr: string, locale: string) {
  return new Date(dateStr).toLocaleDateString(locale === "de" ? "de-DE" : "en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}
---

<section class:list={["py-16 sm:py-20", background === "dark" ? "bg-dark" : "bg-dark-lighter"]}>
  <div class="px-6 sm:px-12 lg:px-20">
    <h2 class="text-2xl sm:text-3xl font-semibold text-white mb-2">{heading}</h2>
    <p class="text-sm text-white/40 mb-10">{subtitle}</p>
    <div class:list={[
      "grid gap-6",
      posts.length === 1 ? "grid-cols-1 max-w-md" :
      posts.length === 2 ? "grid-cols-1 sm:grid-cols-2" :
      posts.length === 3 ? "grid-cols-1 sm:grid-cols-2 lg:grid-cols-3" :
      "grid-cols-1 sm:grid-cols-2 lg:grid-cols-4"
    ]}>
      {posts.map((post: any) => (
        <a
          href={`${prefix}/blog/${post.slug}`}
          class="group rounded-xl overflow-hidden border border-white/5 bg-dark hover:border-white/10 transition-colors"
        >
          {post.featuredImage && (
            <div class="aspect-[16/10] overflow-hidden">
              <img
                src={post.featuredImage + "?w=600&h=375&fit=crop&auto=format"}
                alt={post.title}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
                decoding="async"
              />
            </div>
          )}
          <div class="p-5">
            {post.categories?.[0] && (
              <span class="text-[11px] text-ocean-light font-medium uppercase tracking-wider">{post.categories[0].name}</span>
            )}
            <h3 class="text-sm font-semibold text-white mt-1 line-clamp-2 group-hover:text-ocean-light transition-colors">
              {post.title}
            </h3>
            {post.publishedAt && (
              <time class="mt-2 block text-[11px] text-white/30">{formatDate(post.publishedAt, lang)}</time>
            )}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

---
import { t, type Lang } from "@/lib/i18n";

interface Props {
  heading?: string;
  text?: string;
  buttonText?: string;
  buttonUrl?: string;
  faqSlug?: string;
  blogCategory?: string;
  lang?: Lang;
}

const props = Astro.props;
const lang = props.lang || "en";
const heading = props.heading || t("cta.headline", lang);
const text = props.text || t("cta.text", lang);
const buttonText = props.buttonText || t("cta.book", lang);
const buttonUrl = props.buttonUrl || "https://bookings.rapturecamps.com";
const faqSlug = props.faqSlug;
const blogCategory = props.blogCategory;
const contactHref = lang === "de" ? "/de/contact" : "/contact";
const faqBase = lang === "de" ? "/de/faq" : "/faq";
const blogBase = lang === "de" ? "/de/blog/category" : "/blog/category";

const headingParts = heading.split("\n");
---

<section class="relative py-20 overflow-hidden bg-dark">
  <div class="absolute inset-0 bg-gradient-to-r from-ocean/20 to-dark" />

  <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-semibold text-white leading-tight">
      {headingParts.map((part, i) => (
        i < headingParts.length - 1 ? <>{part}<br /></> : <>{part}</>
      ))}
    </h2>
    <p class="mt-6 text-base text-white/50 max-w-2xl mx-auto">
      {text}
    </p>
    <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={buttonUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-full bg-ocean px-8 py-3.5 text-sm font-semibold text-white transition-all hover:bg-ocean-light"
      >
        {buttonText}
      </a>
      <a
        href={contactHref}
        class="rounded-full border border-white/20 px-8 py-3.5 text-sm font-semibold text-white transition-all hover:bg-white/10"
      >
        {t("general.getInTouch", lang)}
      </a>
    </div>
    {(faqSlug || blogCategory) && (
      <p class="mt-8 text-sm text-white/30">
        {t("general.gotQuestions", lang)}{" "}
        {faqSlug && <><a href={`${faqBase}/${faqSlug}`} class="text-ocean-light hover:underline">FAQ</a>, </>}
        {blogCategory && <>{t("general.browseOur", lang)} <a href={`${blogBase}/${blogCategory}`} class="text-ocean-light hover:underline">Blog</a>, {lang === "de" ? "oder" : "or"} </>}
        <a href={contactHref} class="text-ocean-light hover:underline">{t("general.orMessageUs", lang)}</a>.
      </p>
    )}
  </div>
</section>

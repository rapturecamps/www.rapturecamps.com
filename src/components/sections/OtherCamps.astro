---
/**
 * Shows sibling camps in the same country + cross-destination links.
 * Adapts layout based on sibling count:
 * - 1 sibling: horizontal card (image left, info right)
 * - 2+ siblings: vertical card grid
 */
import { getCampsByCountry, getCountries } from "@/lib/sanity-data";

interface Props {
  countrySlug: string;
  countryName: string;
  currentCampSlug: string;
  lang?: string;
}

const { countrySlug, countryName, currentCampSlug, lang = "en" } = Astro.props;
const prefix = lang === "de" ? "/de" : "";

const allCampsInCountry = await getCampsByCountry(countrySlug, lang);
const siblingCamps = allCampsInCountry.filter((c: any) => c.slug !== `/surfcamp/${countrySlug}/${currentCampSlug}`);

const countries = await getCountries(lang);
const otherCountries = countries.filter((c: any) => {
  const slug = c.slug?.current || c.slug;
  return slug !== countrySlug;
});

const hasSiblings = siblingCamps.length > 0;
const hasOtherCountries = otherCountries.length > 0;
if (!hasSiblings && !hasOtherCountries) return;

const singleSibling = siblingCamps.length === 1;

const siblingTitle = lang === "de"
  ? `Mehr Camps in ${countryName}`
  : `More Camps in ${countryName}`;

const destinationTitle = lang === "de"
  ? "Entdecke andere Reiseziele"
  : "Explore Other Destinations";
---

<section class="py-16 sm:py-20 bg-dark-lighter">
  <div class="px-6 sm:px-12 lg:px-20">
    {hasSiblings && singleSibling && (
      <div class:list={[hasOtherCountries ? "mb-10" : ""]}>
        <h2 class="text-2xl sm:text-3xl font-semibold text-white mb-6">{siblingTitle}</h2>
        {(() => {
          const camp = siblingCamps[0] as any;
          const campSlug = typeof camp.slug === "string" ? camp.slug : camp.slug?.current || "";
          const href = `${prefix}${campSlug}`;
          const image = camp.image || camp.heroImages?.[0];
          return (
            <a href={href} class="group flex flex-col sm:flex-row rounded-xl overflow-hidden border border-white/5 bg-dark hover:border-white/10 transition-colors">
              {image && (
                <div class="sm:w-2/5 lg:w-1/3 shrink-0 overflow-hidden">
                  <img
                    src={image + "?w=800&h=500&fit=crop&auto=format"}
                    alt={camp.name}
                    class="h-full w-full object-cover aspect-[16/10] sm:aspect-auto sm:min-h-[200px] transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              )}
              <div class="flex flex-col justify-center p-6 sm:p-8">
                <h3 class="text-lg font-semibold text-white group-hover:text-ocean-light transition-colors">
                  {camp.name}
                </h3>
                {camp.location && (
                  <p class="text-sm text-white/40 mt-1">{camp.location}</p>
                )}
                {camp.tagline && (
                  <p class="text-sm text-white/50 mt-3 line-clamp-2">{camp.tagline}</p>
                )}
                <span class="mt-4 inline-flex items-center text-sm font-medium text-ocean-light group-hover:text-white transition-colors">
                  {lang === "de" ? "Camp entdecken" : "Explore camp"}
                  <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                  </svg>
                </span>
              </div>
            </a>
          );
        })()}
      </div>
    )}

    {hasSiblings && !singleSibling && (
      <div class:list={[hasOtherCountries ? "mb-10" : ""]}>
        <h2 class="text-2xl sm:text-3xl font-semibold text-white mb-8">{siblingTitle}</h2>
        <div class:list={[
          "grid gap-6",
          siblingCamps.length === 2 ? "grid-cols-1 sm:grid-cols-2" : "grid-cols-1 sm:grid-cols-2 lg:grid-cols-3"
        ]}>
          {siblingCamps.map((camp: any) => {
            const campSlug = typeof camp.slug === "string" ? camp.slug : camp.slug?.current || "";
            const href = `${prefix}${campSlug}`;
            const image = camp.image || camp.heroImages?.[0];
            return (
              <a href={href} class="group rounded-xl overflow-hidden border border-white/5 bg-dark hover:border-white/10 transition-colors">
                {image && (
                  <div class="aspect-[16/10] overflow-hidden">
                    <img
                      src={image + "?w=600&h=375&fit=crop&auto=format"}
                      alt={camp.name}
                      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                )}
                <div class="p-5">
                  <h3 class="text-base font-semibold text-white group-hover:text-ocean-light transition-colors">
                    {camp.name}
                  </h3>
                  {camp.location && (
                    <p class="text-sm text-white/40 mt-1">{camp.location}</p>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      </div>
    )}

    {hasOtherCountries && (
      <div>
        <h3 class="text-lg font-semibold text-white mb-4">{destinationTitle}</h3>
        <div class="flex flex-wrap gap-3">
          {otherCountries.map((c: any) => {
            const slug = c.slug?.current || c.slug;
            return (
              <a
                href={`${prefix}/surfcamp/${slug}`}
                class="group inline-flex items-center gap-3 rounded-full border border-white/10 bg-white/5 pr-5 pl-1.5 py-1.5 text-sm text-white/60 hover:border-ocean/40 hover:text-white transition-colors"
              >
                {c.cardImage && (
                  <img
                    src={c.cardImage + "?w=80&h=80&fit=crop&auto=format"}
                    alt={c.name}
                    class="h-8 w-8 rounded-full object-cover"
                    loading="lazy"
                  />
                )}
                {lang === "de" ? `Surfen in ${c.name}` : `Surf in ${c.name}`}
              </a>
            );
          })}
        </div>
      </div>
    )}
  </div>
</section>

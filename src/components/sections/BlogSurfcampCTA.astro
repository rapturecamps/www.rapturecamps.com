---
/**
 * Contextual surfcamp CTA for blog posts.
 * - Country silo → links to the country's surfcamp page
 * - Topical silo → links to /surfcamp hub
 */
interface Props {
  silo?: string;
  siloIsCountry?: boolean;
  lang?: string;
}

const { silo, siloIsCountry, lang = "en" } = Astro.props;

const prefix = lang === "de" ? "/de" : "";

const COUNTRY_SLUG_MAP: Record<string, string> = {
  Bali: "bali",
  "Costa Rica": "costa-rica",
  Portugal: "portugal",
  Nicaragua: "nicaragua",
  Morocco: "morocco",
};

let href = `${prefix}/surfcamp`;
let heading = lang === "de" ? "Finde dein perfektes Surfcamp" : "Find Your Perfect Surf Camp";
let description = lang === "de"
  ? "Entdecke unsere Surfcamps an den besten Surfspots weltweit."
  : "Explore our surf camps at the best surf spots worldwide.";
let cta = lang === "de" ? "Surfcamps entdecken" : "Explore Surf Camps";

if (siloIsCountry && silo && COUNTRY_SLUG_MAP[silo]) {
  const countrySlug = COUNTRY_SLUG_MAP[silo];
  href = `${prefix}/surfcamp/${countrySlug}`;
  heading = lang === "de" ? `Plane deinen ${silo} Surftrip` : `Plan Your ${silo} Surf Trip`;
  description = lang === "de"
    ? `Entdecke unsere Surfcamps in ${silo} und finde die perfekte Welle.`
    : `Discover our surf camps in ${silo} and catch the perfect wave.`;
  cta = lang === "de" ? `${silo} Surfcamps` : `${silo} Surf Camps`;
}
---

{silo && (
  <aside class="my-12 rounded-2xl border border-white/10 bg-gradient-to-br from-ocean/10 to-dark-lighter p-6 sm:p-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <h3 class="font-display text-xl font-bold text-white mb-1">{heading}</h3>
        <p class="text-sm text-white/50">{description}</p>
      </div>
      <a
        href={href}
        class="inline-flex items-center justify-center shrink-0 rounded-full bg-ocean px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-ocean-light"
      >
        {cta}
        <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </aside>
)}

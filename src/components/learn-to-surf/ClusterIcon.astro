---
interface Props {
  icon?: string;
  class?: string;
}

const { icon, class: className = "h-6 w-6" } = Astro.props;
const known = ["waves", "paddle", "surfboard", "arrowUp", "refresh", "brain", "dumbbell", "skateboard", "shield", "camera"];
const showFallback = !icon || !known.includes(icon);
---

{icon === "waves" && (
  <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M2 6c.6.5 1.2 1 2.5 1C7 7 7 5 9.5 5c2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1" />
    <path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1" />
    <path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1" />
  </svg>
)}

{icon === "paddle" && (
  <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1" />
    <path d="M17 6a3 3 0 0 0-3 3v2" />
    <path d="M10 8.5 7.5 11" />
    <circle cx="17" cy="4" r="1.5" />
    <path d="M14 11c-1 1-2.5 2-4 2H8l-3 3" />
    <path d="M14 11 9 6" />
  </svg>
)}

{icon === "surfboard" && (
  <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M18 2c-2 0-5.5 1.5-8 4s-4.5 5.5-5 8c-.3 1.5 0 3 1 4s2.5 1.3 4 1c2.5-.5 5.5-2.5 8-5s4-6 4-8c0-1.5-.5-2.5-1.5-3S19.5 2 18 2Z" />
    <path d="m8 16 2.5-2.5" />
    <path d="M6 18 4 20" />
  </svg>
)}

{icon === "arrowUp" && (
  <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 20V4" />
    <path d="m5 11 7-7 7 7" />
    <path d="M2 20c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1" />
  </svg>
)}

{icon === "refresh" && (
  <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12a9 9 0 0 1-15.36 6.36" />
    <path d="M3 12a9 9 0 0 1 15.36-6.36" />
    <path d="m15 9 3-3 3 3" />
    <path d="m6 15-3 3-3-3" />
  </svg>
)}

{icon === "brain" && (
  <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z" />
    <path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z" />
    <path d="M12 5v14" />
    <path d="M6.5 10.5c1.5 0 3 .5 3.5 2" />
    <path d="M17.5 10.5c-1.5 0-3 .5-3.5 2" />
  </svg>
)}

{icon === "dumbbell" && (
  <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M14.4 14.4 9.6 9.6" />
    <path d="M18.657 21.485a2 2 0 1 1-2.829-2.828l-1.767-1.768a2 2 0 1 1-2.829-2.829l6.364-6.364a2 2 0 1 1 2.829 2.829l1.767 1.767a2 2 0 1 1 2.828 2.829Z" />

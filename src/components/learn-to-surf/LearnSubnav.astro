---
import ClusterIcon from "./ClusterIcon.astro";

interface Cluster {
  title: string;
  slug: string;
  icon?: string;
}

interface Props {
  clusters: Cluster[];
  activeCluster?: string;
  lang?: "en" | "de";
}

const { clusters, activeCluster, lang = "en" } = Astro.props;
const prefix = lang === "de" ? "/de" : "";
const isHub = !activeCluster;
const activeLabel = isHub
  ? (lang === "de" ? "Alle Themen" : "All Topics")
  : clusters.find((c) => c.slug === activeCluster)?.title || "Topics";
---

<nav id="learn-subnav" class="sticky z-40 bg-dark/95 backdrop-blur-md border-b border-white/5 opacity-0 -translate-y-2 pointer-events-none transition-all duration-300">
  <div class="mx-auto w-full px-4 sm:px-6 lg:px-10">

    {/* Desktop: horizontal pill tabs */}
    <div class="hidden lg:flex items-center gap-1.5 h-11">
      <a
        href={`${prefix}/learn-to-surf`}
        class:list={[
          "whitespace-nowrap text-xs px-3 py-1.5 rounded-full transition-colors",
          isHub
            ? "bg-white/10 text-white font-medium"
            : "text-white/40 hover:text-white/70",
        ]}
      >
        {lang === "de" ? "Alle" : "All"}
      </a>
      {clusters.map((c) => (
        <a
          href={`${prefix}/learn-to-surf/${c.slug}`}
          class:list={[
            "whitespace-nowrap text-xs px-3 py-1.5 rounded-full transition-colors",
            activeCluster === c.slug
              ? "bg-white/10 text-white font-medium"
              : "text-white/40 hover:text-white/70",
          ]}
        >
          {c.title}
        </a>
      ))}
    </div>

    {/* Mobile: collapsible panel */}
    <div class="lg:hidden">
      <button
        class="learn-subnav-toggle w-full flex items-center justify-between h-14"
        aria-expanded="false"
      >
        <span class="text-sm font-medium text-white truncate">{activeLabel}</span>
        <svg class="learn-subnav-chevron h-4 w-4 text-white/40 transition-transform duration-200 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
        </svg>
      </button>
      <div class="learn-subnav-panel hidden pt-1 pb-5 space-y-0.5">
        <a
          href={`${prefix}/learn-to-surf`}
          class:list={[
            "block px-3 py-2 rounded-lg text-sm transition-colors",
            isHub
              ? "text-white bg-white/5 font-medium"
              : "text-white/50 hover:text-white hover:bg-white/5",
          ]}
        >
          {lang === "de" ? "Alle Themen" : "All Topics"}
        </a>
        {clusters.map((c) => (
          <a
            href={`${prefix}/learn-to-surf/${c.slug}`}
            class:list={[
              "flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm transition-colors",
              activeCluster === c.slug
                ? "text-white bg-white/5 font-medium"
                : "text-white/50 hover:text-white hover:bg-white/5",
            ]}
          >
            <span class:list={[
              "flex-shrink-0",
              activeCluster === c.slug ? "text-ocean" : "text-white/30",
            ]}>
              <ClusterIcon icon={c.icon} class="h-4 w-4" />
            </span>
            <span>{c.title}</span>
          </a>
        ))}
      </div>
    </div>

  </div>
</nav>

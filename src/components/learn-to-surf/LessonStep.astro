---
const { node } = Astro.props as any;
const heading = node?.heading;
const steps = node?.steps ?? [];
---

<section class="py-10">
  {heading && (
    <h3 class="font-display text-xl font-bold text-white !mb-10">{heading}</h3>
  )}
  <div class="space-y-8">
    {steps.map((step, i) => (
      <div>
        <div class="flex items-center gap-4 mb-2">
          <span class="flex-shrink-0 w-10 h-10 rounded-full bg-ocean/20 border border-ocean/30 flex items-center justify-center text-sm font-bold text-ocean">
            {i + 1}
          </span>
          <h4 class="font-display text-lg font-semibold text-white !m-0">{step.title}</h4>
        </div>
        <div class="pl-14">
          {step.description && (
            <p class="text-white/55 leading-relaxed mb-3">{step.description}</p>
          )}
          {step.resolvedImageUrl && (
            <img
              src={`${step.resolvedImageUrl}?w=720&auto=format`}
              alt={step.title}
              width={720}
              height={405}
              loading="lazy"
              decoding="async"
              class="rounded-xl w-full max-w-lg mb-3"
            />
          )}
          {step.video && (
            <div class="aspect-video max-w-lg rounded-xl overflow-hidden mb-3">
              <iframe
                src={step.video}
                title={step.title}
                class="w-full h-full"
                loading="lazy"
                allow="accelerometer; autoplay; encrypted-media; gyroscope"
                allowfullscreen
              />
            </div>
          )}
          {step.tips?.length > 0 && (
            <div class="mt-3 rounded-lg bg-ocean/5 border border-ocean/10 px-4 py-3">
              <ul class="space-y-1">
                {step.tips.map((tip) => (
                  <li class="flex gap-2 text-sm text-white/60">
                    <span class="text-ocean mt-0.5 flex-shrink-0">→</span>
                    <span>{tip}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    ))}
  </div>
</section>

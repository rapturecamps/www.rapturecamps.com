---
import ElfsightReviews from "@/components/sections/ElfsightReviews.astro";
import { type Lang } from "@/lib/i18n";

interface Props {
  block: {
    heading?: string;
    elfsightAppId: string;
    background?: string;
  };
  lang?: Lang;
}

const { block, lang = "en" } = Astro.props;
---

{block.elfsightAppId && (
  <ElfsightReviews
    heading={block.heading}
    appId={block.elfsightAppId}
    background={block.background}
    lang={lang}
  />
)}

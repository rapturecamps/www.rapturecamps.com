---
interface Stat {
  value: string;
  label: string;
  prefix?: string;
}

interface Props {
  block: {
    stats?: Stat[];
    background?: string;
  };
}

const { block } = Astro.props;
const bg = block.background === "dark-lighter" ? "bg-dark-lighter" : "bg-dark";
const stats = block.stats || [];
---

<section class:list={["py-14 sm:py-20", bg]}>
  <div class="px-6 sm:px-12 lg:px-20">
    <div class:list={[
      "grid gap-10 sm:gap-12 text-center",
      stats.length <= 2 ? "grid-cols-2" :
      stats.length === 3 ? "grid-cols-3" :
      "grid-cols-2 sm:grid-cols-4"
    ]}>
      {stats.map((stat) => (
        <div>
          {stat.prefix && (
            <p class="text-[10px] text-white/25 uppercase tracking-wider mb-1">{stat.prefix}</p>
          )}
          <p class="text-4xl sm:text-5xl lg:text-6xl font-bold text-ocean-light leading-none">
            {stat.value}
          </p>
          <p class="text-[10px] sm:text-xs text-white/30 uppercase tracking-[0.15em] mt-2">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>

---
interface Activity {
  time?: string;
  title: string;
  category?: string;
}

interface Day {
  dayNumber: number;
  dayName?: string;
  theme?: string;
  activities?: Activity[];
}

interface Props {
  block: {
    heading?: string;
    subtext?: string;
    days?: Day[];
    background?: string;
  };
}

const { block } = Astro.props;
const bg = block.background === "dark-lighter" ? "bg-dark-lighter" : "bg-dark";
const days = block.days || [];

const categoryStyles: Record<string, { text: string; bg: string }> = {
  Surf:     { text: "text-ocean-light",  bg: "bg-ocean-light/15" },
  Yoga:     { text: "text-violet-400",   bg: "bg-violet-400/15" },
  Wellness: { text: "text-green-400",    bg: "bg-green-400/15" },
  Culture:  { text: "text-amber-400",    bg: "bg-amber-400/15" },
};
---

<section class:list={["py-16 sm:py-20", bg]}>
  <div class="px-6 sm:px-12 lg:px-20">
    {(block.heading || block.subtext) && (
      <div class="max-w-4xl mx-auto text-center mb-12">
        {block.heading && (
          <h2 class="text-2xl sm:text-3xl lg:text-4xl font-semibold text-white mb-3">
            {block.heading}
          </h2>
        )}
        {block.subtext && (
          <p class="text-base text-white/45 max-w-2xl mx-auto leading-relaxed">{block.subtext}</p>
        )}
      </div>
    )}

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 max-w-6xl mx-auto">
      {days.map((day) => (
        <div class="rounded-xl border border-white/5 bg-dark-lighter overflow-hidden">
          <div class="flex items-center justify-between px-5 pt-5 pb-3">
            <div class="flex items-center gap-3">
              <span class="text-[10px] font-bold uppercase tracking-wider text-ocean-light bg-ocean-light/10 px-2.5 py-1 rounded-full">
                Day {day.dayNumber}
              </span>
              <h3 class="text-base sm:text-lg font-semibold text-white">
                {day.dayName}
              </h3>
            </div>
            {day.theme && (
              <span class="text-xs text-white/30 italic">{day.theme}</span>
            )}
          </div>

          {day.activities && day.activities.length > 0 && (
            <div class="px-5 pb-5">
              <div class="border-t border-white/5 pt-4 space-y-2.5">
                {day.activities.map((act) => {
                  const cat = act.category ? categoryStyles[act.category] : null;
                  return (
                    <div class="flex items-start gap-3">
                      {act.time ? (
                        <span class="text-xs text-white/25 font-mono w-14 shrink-0 pt-0.5">{act.time}</span>
                      ) : (
                        <span class="w-14 shrink-0" />
                      )}
                      <span class="text-sm text-white/60 flex-1">{act.title}</span>
                      {act.category && cat && (
                        <span class:list={["text-[9px] uppercase tracking-wider font-bold px-2 py-0.5 rounded-full shrink-0", cat.text, cat.bg]}>
                          {act.category}
                        </span>
                      )}
                    </div>
                  );
                })}
              </div>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

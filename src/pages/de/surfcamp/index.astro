---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/sections/Hero.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import BlockRenderer from "@/components/blocks/BlockRenderer.astro";
import { resizeWidth } from "@/lib/image-utils";
import { getPageBySlug } from "@/lib/sanity-data";

const page = await getPageBySlug("surfcamp", "de");

const heroTitle = page?.heroTitle || "Wähle dein Reiseziel";
const heroTagline = page?.heroTagline || "";
const heroImages = page?.heroImages?.length
  ? page.heroImages
  : [
      "https://cdn.sanity.io/images/ypmt1bmc/production/301aa2ac02adaa1b397bb4be507f4adb66670c0e-1920x1280.jpg",
      "https://cdn.sanity.io/images/ypmt1bmc/production/e1696b4d5fc2c7f1fbdb73229838d338a06c8883-1920x1281.jpg",
      "https://cdn.sanity.io/images/ypmt1bmc/production/c9538fbcc49d9a29c0f8cf327a820fa747a5834a-1920x1440.jpg",
      "https://cdn.sanity.io/images/ypmt1bmc/production/645fece67ca00725dc995d9e5bda9fe416b19961-1920x1276.jpg",
    ];

const seoTitle = page?.seo?.metaTitle || "Surfcamps weltweit · Rapture";
const seoDesc = page?.seo?.metaDescription || "Wähle dein Surfcamp-Reiseziel. Rapture Surfcamps bietet Camps auf Bali, in Costa Rica und Portugal.";
const ogImage = page?.seoOgImageUrl
  || (heroImages[0] ? resizeWidth(heroImages[0], 1200) : undefined);

const useHeroAsH1 = page?.useHeroAsH1 === true;
const seoH1 = page?.seoH1;

const blocks = page?.pageBuilder || [];
const hasSanityBlocks = blocks.length > 0;
const h1BlockIndex = blocks.findIndex((b: any) => b._type === "contentBlock");
---

<BaseLayout
  title={seoTitle}
  description={seoDesc}
  ogImage={ogImage}
  noindex={page?.seo?.noindex}
  preloadImage={heroImages[0]}
  lang="de"
>
  <Hero
    title={heroTitle}
    tagline={heroTagline}
    headingTag={useHeroAsH1 ? "h1" : "p"}
    backgroundImage={heroImages[0]}
    backgroundImages={heroImages}
  >
    <Breadcrumbs inline crumbs={[{ label: "Surfcamps" }]} />
  </Hero>

  {!useHeroAsH1 && seoH1 && (
    <section class="pt-16 sm:pt-20 pb-0 bg-dark">
      <div class="px-6 sm:px-12 lg:px-20">
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-semibold text-white">{seoH1}</h1>
      </div>
    </section>
  )}

  {hasSanityBlocks && (
    <BlockRenderer
      blocks={blocks}
      lang="de"
      h1BlockIndex={!useHeroAsH1 && !seoH1 && h1BlockIndex >= 0 ? h1BlockIndex : undefined}
    />
  )}
</BaseLayout>

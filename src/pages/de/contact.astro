---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/sections/Hero.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";

const contactMethods = [
  { label: "WhatsApp", desc: "Schnelle Antworten", href: "https://wa.me/+447700177360", icon: "M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" },
  { label: "Telegram", desc: "Chatte mit unserem Bot", href: "https://t.me/rapturecampsbot", icon: "m22 2-7 20-4-9-9-4Z M22 2 11 13" },
  { label: "Online Meeting / Rückruf", desc: "Buche einen Termin und wir rufen dich an", href: "/de/meet-us", icon: "M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" },
];
---

<BaseLayout
  title="Kontakt | Rapture Surfcamps"
  description="Nimm Kontakt mit Rapture Surfcamps auf. Stelle Fragen zu unseren Surfcamps per E-Mail, WhatsApp, Telegram oder über unser Kontaktformular."
  ogImage="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=1200&h=630&fit=crop"
>
  <Hero
    title="Kontaktiere uns"
    headingTag="h1"
    backgroundVideo="https://vz-79cee76e-e6d.b-cdn.net/e3cb3e25-a814-498e-a191-6a12ed058af5/play_720p.mp4"
  >
    <Breadcrumbs inline crumbs={[{ label: "Kontakt" }]} />
  </Hero>

  <section class="py-20 bg-dark">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-1 space-y-5">
          <h2 class="text-xl font-semibold text-white">Schreib uns</h2>
          <p class="text-sm text-white/40">Wähle deine bevorzugte Kontaktmöglichkeit. Wir antworten in der Regel innerhalb weniger Stunden.</p>
          <div class="space-y-3">
            {contactMethods.map(({ label, desc, href, icon }) => (
              <a
                href={href}
                target={href.startsWith("http") ? "_blank" : undefined}
                rel={href.startsWith("http") ? "noopener noreferrer" : undefined}
                class="flex items-center gap-4 rounded-xl border border-white/10 p-4 transition-all hover:border-white/20 hover:bg-white/5"
              >
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-white/5 text-white/40">
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d={icon} />
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-white">{label}</p>
                  <p class="text-xs text-white/40">{desc}</p>
                </div>
              </a>
            ))}
          </div>
        </div>

        <div class="lg:col-span-2">
          <div class="rounded-2xl bg-dark-lighter border border-white/5 p-8 md:p-10">
            <h2 class="text-xl font-semibold text-white mb-8">Nachricht senden</h2>
            <form
              name="zsWebToCase_105098000032334342"
              id="zsWebToCase_105098000032334342"
              action="https://help.rapturecamps.com/support/WebToCase"
              method="POST"
              enctype="multipart/form-data"
              class="space-y-5"
            >
              <input type="hidden" name="xnQsjsdp" value="edbsn02b8dc7e1b707441cd82c295a3b2ecb2" />
              <input type="hidden" name="xmIwtLD" value="edbsnff5a3a5fd084e6c963c7d2cc1afe1d0d731368373932ee0e905c73082a1bc50e" />
              <input type="hidden" name="xJdfEaS" value="" />
              <input type="hidden" name="actionType" value="Q2FzZXM=" />
              <input type="hidden" id="property(module)" value="Cases" />
              <input type="hidden" id="dependent_field_values_Cases" value='{"JSON_VALUES":{},"JSON_SELECT_VALUES":{},"JSON_MAP_DEP_LABELS":[]}' />
              <input type="hidden" name="returnURL" value="https://www.rapturecamps.com/de/thank-you" />
              <input type="hidden" name="Subject" value="Surf Trip - Enquiry" />

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="contact-name" class="block text-xs font-medium text-white/50 mb-2">Name <span class="text-red-400">*</span></label>
                  <input type="text" id="contact-name" name="Contact Name" maxlength="120" required class="w-full rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder-white/20 transition-colors focus:border-ocean focus:ring-1 focus:ring-ocean/50 outline-none" placeholder="Dein Name" />
                </div>
                <div>
                  <label for="email" class="block text-xs font-medium text-white/50 mb-2">E-Mail <span class="text-red-400">*</span></label>
                  <input type="email" id="email" name="Email" maxlength="120" required class="w-full rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder-white/20 transition-colors focus:border-ocean focus:ring-1 focus:ring-ocean/50 outline-none" placeholder="deine@email.com" />
                </div>
              </div>
              <div>
                <label for="location" class="block text-xs font-medium text-white/50 mb-2">Reiseziel</label>
                <select id="location" name="Location" class="w-full rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-sm text-white transition-colors focus:border-ocean focus:ring-1 focus:ring-ocean/50 outline-none">
                  <option value="" class="bg-dark-lighter">Reiseziel wählen</option>
                  <option value="Head Office" class="bg-dark-lighter">Hauptbüro</option>
                  <option value="Bali - Green Bowls" class="bg-dark-lighter">Bali - Green Bowl</option>
                  <option value="Bali - Padang Padang" class="bg-dark-lighter">Bali - Padang Padang</option>
                  <option value="Costa Rica - Avellanas" class="bg-dark-lighter">Costa Rica - Avellanas</option>
                  <option value="Portugal - Ericeira" class="bg-dark-lighter">Portugal - Ericeira</option>
                  <option value="Portugal - Ericeira - Coxos" class="bg-dark-lighter">Portugal - Coxos Surf Villa</option>
                  <option value="Portugal - Milfontes" class="bg-dark-lighter">Portugal - Milfontes</option>
                </select>
              </div>
              <div>
                <label for="description" class="block text-xs font-medium text-white/50 mb-2">Nachricht</label>
                <textarea id="description" name="Description" rows="5" maxlength="3000" class="w-full rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder-white/20 transition-colors focus:border-ocean focus:ring-1 focus:ring-ocean/50 outline-none resize-none" placeholder="Erzähl uns von deinen Reiseplänen..."></textarea>
              </div>
              <button type="submit" class="w-full rounded-full bg-ocean px-8 py-3.5 text-sm font-semibold text-white transition-all hover:bg-ocean-light">
                Nachricht senden
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

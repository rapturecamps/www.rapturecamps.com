---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/sections/Hero.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import CTASection from "@/components/sections/CTASection.astro";
import ClusterCard from "@/components/learn-to-surf/ClusterCard.astro";
import { getLearnClusters, getLearnLessons } from "@/lib/sanity-data";

const clusters = await getLearnClusters("de");
const lessons = await getLearnLessons("de");

const enClusters = clusters.length ? clusters : await getLearnClusters("en");
const enLessons = lessons.length ? lessons : await getLearnLessons("en");

const clusterCounts: Record<string, number> = {};
for (const lesson of enLessons) {
  const cs = lesson.clusterSlug;
  if (cs) clusterCounts[cs] = (clusterCounts[cs] || 0) + 1;
}

const seoTitle = "Surfen Lernen · Rapture";
const seoDesc =
  "Surfen lernen von der ersten Welle bis zu fortgeschrittenen Manövern. Kostenlose Lektionen, Übungen und Expertentipps einer ISA-zertifizierten Surfschule.";
---

<BaseLayout title={seoTitle} description={seoDesc}>
  <Hero
    title="Surfen Lernen"
    subtitle="Von der ersten Welle bis zu fortgeschrittenen Manövern — lerne Surfen mit kostenlosen Lektionen einer ISA-zertifizierten Surfschule."
    tagline="Surf Wissenshub"
    backgroundImage="https://cdn.sanity.io/images/ypmt1bmc/production/0f4699ad7ef6f2461c02fb321f9743ad8e649d06-1920x1080.jpg?w=1920&h=1080&fit=crop&auto=format"
    centered
  >
    <div class="flex justify-center">
      <Breadcrumbs inline crumbs={[{ label: "Surfen Lernen" }]} />
    </div>
  </Hero>


  <section class="py-16 sm:py-20 bg-dark">
    <div class="mx-auto max-w-6xl px-6 sm:px-8">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <h1 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">
          Dein kompletter Guide zum Surfen Lernen
        </h1>
        <p class="text-lg text-white/50 leading-relaxed">
          Ob du zum ersten Mal auf dem Board stehst oder an deinem Cutback arbeitest — unsere
          umfassenden Surflektionen decken jede Fähigkeit ab, die du brauchst. Erstellt von
          ISA-zertifizierten Coaches bei Rapture Surfcamps mit jahrelanger Erfahrung.
        </p>
      </div>

      {enClusters.length > 0 ? (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {enClusters.map((cluster: any) => (
            <ClusterCard
              title={cluster.title}
              slug={cluster.slug}
              description={cluster.description}
              icon={cluster.icon}
              featuredImageUrl={cluster.featuredImageUrl}
              lessonCount={clusterCounts[cluster.slug] || 0}
              lang="de"
            />
          ))}
        </div>
      ) : (
        <div class="rounded-2xl border border-white/10 bg-dark-lighter p-12 text-center">
          <p class="text-white/40 text-lg">Inhalte werden vorbereitet. Schau bald wieder vorbei!</p>
        </div>
      )}
    </div>
  </section>

  <section class="py-12 bg-dark-lighter">
    <div class="mx-auto max-w-6xl px-6 sm:px-8">
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 rounded-xl border border-white/10 bg-dark px-6 py-5">
        <img src="/images/rapturecamps-logo.svg" alt="Rapture Surfcamps" width={48} height={48} class="w-12 h-12 rounded-lg" />
        <div>
          <p class="text-sm font-semibold text-white">Erstellt von Rapture Surfcamps</p>
          <p class="text-xs text-white/40 mt-0.5">ISA-zertifizierte Surfschule · Anerkannt vom portugiesischen Surfverband</p>
        </div>
        <a href="/de/about" class="sm:ml-auto text-xs text-ocean hover:text-white transition-colors">Über uns →</a>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>

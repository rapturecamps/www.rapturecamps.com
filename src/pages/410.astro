---
import BaseLayout from "@/layouts/BaseLayout.astro";

Astro.response.status = 410;
---

<BaseLayout title="Page Removed · Rapture" noindex>
  <div class="flex min-h-screen items-center justify-center px-4 bg-dark">
    <div class="text-center">
      <p class="text-8xl font-bold text-white/20">410</p>
      <h1 class="mt-4 text-3xl font-bold text-white">Page Removed</h1>
      <p class="mt-4 text-white/40 max-w-md mx-auto">
        This page has been permanently removed. It's no longer available on our site.
      </p>
      <div class="mt-8 flex gap-4 justify-center">
        <a href="/" class="rounded-full bg-ocean px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-ocean-light">
          Go Home
        </a>
        <a href="/surfcamp" class="rounded-full border border-white/20 px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-white/10">
          Browse Destinations
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

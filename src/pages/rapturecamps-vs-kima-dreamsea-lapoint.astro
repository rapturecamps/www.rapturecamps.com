---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/sections/Hero.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";

const seoTitle = "Rapture Surfcamps vs Dreamsea vs Kima Surf vs Lapoint — Honest Comparison";
const seoDesc = "Choosing a surf camp? Compare Rapture Surfcamps against Dreamsea, Kima Surf, and Lapoint across destinations, pricing, coaching, food, and accommodation.";

const competitors = [
  {
    name: "Rapture Surfcamps",
    slug: "rapture",
    founded: "2003",
    tagline: "Since 2003 — The Original",
    destinations: "Bali, Portugal, Costa Rica, Morocco, Nicaragua",
    destCount: "6–8 camps across 5 countries",
    accommodation: "Shared rooms, twin/double, private rooms, glamping, premium villas",
    surfProgram: "All-level coaching, max 5:1 ratio, 2 sessions/day, video analysis included",
    mealsIncluded: "Breakfast + dinner Mon–Fri (3-course)",
    yoga: "Daily, included",
    priceFrom: "€45/night",
    priceNote: "Modular: book accommodation only, or add surf/yoga/meals à la carte",
    cancellation: "Free up to 30 days",
    arrival: "Any day — even 1 night",
    languages: "EN, DE, PT, ES",
    unique: ["20+ years experience", "85k+ guests served", "Small camps (~20 guests) — everyone knows everyone", "Arrive & depart any day (no fixed schedules)", "Book accommodation only — add extras daily", "Free surf equipment use all day, every day", "Returning customer discounts (cross-destination)", "Student discounts available", "Max 5:1 coaching ratio", "Premium villa options (infinity pool)", "Retreat hosting program", "10% group discount (4+)"],
    highlight: true,
  },
  {
    name: "Dreamsea",
    slug: "dreamsea",
    founded: "2013",
    tagline: "The Glamping Pioneer",
    destinations: "Bali, Costa Rica, France, Morocco, Nicaragua, Portugal, Spain, Sri Lanka",
    destCount: "14 locations across 8 countries",
    accommodation: "Glamping tents, shared tents, surf houses, hotels, bungalows",
    surfProgram: "3 levels (0–2), 1:4 to 1:8 ratio, courses sold separately",
    mealsIncluded: "Varies: breakfast only (Bali) or full board (Europe)",
    yoga: "Paid add-on (€10–60)",
    priceFrom: "€322/week",
    priceNote: "Accommodation + food only — surf courses extra (€170–280)",
    cancellation: "Not disclosed",
    arrival: "Fixed check-in days (Sat/Wed)",
    languages: "EN, ES, DE",
    unique: ["Glamping/outdoor accommodation specialist", "Strong sustainability brand", "Own surfboard brand (Pristine)", "Sailing charter (Dreamsea Oceanis)", "Surfskate bowls at camps", "14 destinations in 8 countries"],
    highlight: false,
  },
  {
    name: "Kima Surf",
    slug: "kima",
    founded: "1995",
    tagline: "The Bali Specialist",
    destinations: "Bali (Canggu, Seminyak, Uluwatu, Bukit), Sri Lanka (Weligama, Hiriketiya)",
    destCount: "6 camps in 2 countries",
    accommodation: "Dorms, standard/superior/deluxe rooms, suites, private villas",
    surfProgram: "Surf guiding 2x daily 7 days/week included, max 6:1 groups, video analysis 6x/week",
    mealsIncluded: "3-course breakfast included; dinner NOT included at most camps",
    yoga: "6 days/week, included",
    priceFrom: "€54/night",
    priceNote: "Accommodation + breakfast + guiding — no lessons for beginners, no dinner",
    cancellation: "Full payment before check-in",
    arrival: "Flexible",
    languages: "EN, DE",
    unique: ["Deepest Bali specialization (4 camps)", "14 guided surf sessions/week included", "Resort facilities (climbing walls, ice baths)", "5m deep diving pool & counter-current", "Co-working spaces", "1% discount per night (long stays)"],
    highlight: false,
  },
  {
    name: "Lapoint",
    slug: "lapoint",
    founded: "2008",
    tagline: "The Scandinavian Brand",
    destinations: "Portugal, Bali, Sri Lanka, Costa Rica, Nicaragua, El Salvador, Fuerteventura, Norway, Maldives",
    destCount: "10 destinations across 9 countries",
    accommodation: "Dorms, twin rooms, double rooms",
    surfProgram: "4 structured levels + guiding, multiple packages (intensive, 1:1, longboarding)",
    mealsIncluded: "Breakfast included; dinner varies by camp",
    yoga: "Included in Yoga & Surf package",
    priceFrom: "€396/week",
    priceNote: "Includes accommodation, breakfast, surf course — no dinner",
    cancellation: "Free rebooking up to 14 days",
    arrival: "Fixed arrival days",
    languages: "EN, SE, NO, DK, DE, CH, AT, FR",
    unique: ["100k+ guests, Scandinavian quality", "Maldives surf cruise", "Work & Surf co-working package", "1:1 private coaching", "Longboarding course (Bali)", "4-day short trips available", "Celebrity endorsements (Laura Crane, Birk Ruud)"],
    highlight: false,
  },
];

const comparisonRows = [
  { label: "Founded", key: "founded" },
  { label: "Destinations", key: "destCount" },
  { label: "Accommodation", key: "accommodation" },
  { label: "Surf Program", key: "surfProgram" },
  { label: "Meals Included", key: "mealsIncluded" },
  { label: "Yoga", key: "yoga" },
  { label: "Starting Price", key: "priceFrom" },
  { label: "What's Included", key: "priceNote" },
  { label: "Cancellation", key: "cancellation" },
  { label: "Arrival Policy", key: "arrival" },
  { label: "Languages", key: "languages" },
] as const;
---

<BaseLayout title={seoTitle} description={seoDesc}>
  <Hero
    title={"How Rapture\nCompares"}
    subtitle="An honest look at four of the world's leading surf camp brands — so you can choose the one that fits you best."
    tagline="Surf Camp Comparison 2026"
    backgroundImage="https://cdn.sanity.io/images/ypmt1bmc/production/a3c1efbd623ad78fe080476cd9f6e24bb6ed1470-1920x1080.jpg?w=1920&h=1080&fit=crop&auto=format"
    headingTag="h1"
    centered
  >
    <div class="flex justify-center">
      <Breadcrumbs inline crumbs={[{ label: "Surf Camp Comparison" }]} />
    </div>
  </Hero>

  <!-- Intro -->
  <section class="py-20 sm:py-28 bg-dark">
    <div class="max-w-4xl mx-auto px-6 sm:px-12 lg:px-20 text-center">
      <p class="text-xs uppercase tracking-[0.25em] text-ocean-light/60 font-light mb-4">The Honest Truth</p>
      <h2 class="text-3xl sm:text-4xl font-semibold text-white mb-8">Choosing the Right Surf Camp Matters</h2>
      <div class="space-y-4 text-base sm:text-lg text-white/50 leading-relaxed">
        <p>Every surf camp has its strengths. We built this page because we believe you deserve transparent information — not just marketing spin. We've researched Dreamsea, Kima Surf, and Lapoint thoroughly so you can make an informed decision.</p>
        <p>We're biased, of course — we think Rapture is the best choice for most surfers. But we'll be upfront about where our competitors shine too.</p>
      </div>
      <div class="mt-8 bg-white/[0.03] border border-white/5 rounded-xl px-6 py-5 max-w-2xl mx-auto">
        <p class="text-xs text-white/30 leading-relaxed text-center"><strong class="text-white/40">A note on accuracy:</strong> We do our best to keep this comparison up to date, but our competitors regularly change their concepts, pricing, packages, and policies. This guide reflects our research as of early 2026 and should not be taken as guaranteed at all times. When in doubt, check each brand's website directly for their latest offering.</p>
      </div>
    </div>
  </section>

  <!-- Rapture Stats Bar -->
  <section class="py-14 sm:py-20 bg-dark-lighter border-y border-white/5">
    <div class="px-6 sm:px-12 lg:px-20">
      <p class="text-xs uppercase tracking-[0.25em] text-ocean-light/60 font-light mb-10 text-center">Rapture Surfcamps at a Glance</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-10 sm:gap-12 text-center">
        {[
          { value: "20+", label: "Years Running", icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" },
          { value: "85k+", label: "Happy Guests", icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" },
          { value: "~20", label: "Guests per Camp", icon: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a2 2 0 110-4 2 2 0 010 4z" },
          { value: "5:1", label: "Coaching Ratio", icon: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" },
          { value: "5", label: "Countries", icon: "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" },
          { value: "Any", label: "Arrival Day", icon: "M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" },
        ].map((stat) => (
          <div>
            <svg class="w-6 h-6 mx-auto mb-3 text-ocean-light/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={stat.icon} />
            </svg>
            <p class="text-3xl sm:text-4xl lg:text-5xl font-bold text-ocean-light leading-none">{stat.value}</p>
            <p class="text-[10px] sm:text-xs text-white/30 uppercase tracking-[0.15em] mt-2">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Competitor Cards Overview -->
  <section class="py-20 sm:py-28 bg-dark">
    <div class="max-w-6xl mx-auto px-6 sm:px-12 lg:px-20">
      <div class="text-center mb-14">
        <p class="text-xs uppercase tracking-[0.25em] text-ocean-light/60 font-light mb-4">The Contenders</p>
        <h2 class="text-3xl sm:text-4xl font-semibold text-white">Four Surf Camps, One Goal</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {competitors.map((c) => (
          <div class:list={[
            "rounded-xl p-6 sm:p-7 transition-colors relative flex flex-col",
            c.highlight
              ? "bg-ocean-light/[0.06] border-2 border-ocean-light/30"
              : "bg-dark-lighter border border-white/5 hover:border-white/10"
          ]}>
            {c.highlight && (
              <span class="absolute -top-3 left-6 bg-ocean-light text-dark text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-full">That's Us</span>
            )}
            <p class="text-xs uppercase tracking-[0.2em] text-ocean-light/50 font-light mb-1">Est. {c.founded}</p>
            <h3 class="text-xl font-semibold text-white mb-1">{c.name}</h3>
            <p class="text-xs text-white/30 mb-4">{c.tagline}</p>
            <p class="text-sm text-white/40 leading-relaxed mb-4">{c.destinations}</p>
            <div class="mt-auto">
              <p class="text-2xl font-bold text-ocean-light mb-0.5">from {c.priceFrom}</p>
              <p class="text-[10px] text-white/25 uppercase tracking-wider min-h-[2lh]">{c.destCount}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Full Comparison Table -->
  <section class="py-20 sm:py-28 bg-dark-lighter">
    <div class="max-w-6xl mx-auto px-6 sm:px-12 lg:px-20">
      <div class="text-center mb-14">
        <p class="text-xs uppercase tracking-[0.25em] text-ocean-light/60 font-light mb-4">Side by Side</p>
        <h2 class="text-3xl sm:text-4xl font-semibold text-white">The Full Comparison</h2>
      </div>

      <!-- Mobile: stacked cards -->
      <div class="lg:hidden space-y-8">
        {comparisonRows.map((row) => (
          <div>
            <p class="text-xs uppercase tracking-[0.2em] text-ocean-light/60 font-light mb-3">{row.label}</p>
            <div class="grid sm:grid-cols-2 gap-3">
              {competitors.map((c) => (
                <div class:list={[
                  "rounded-lg px-4 py-3",
                  c.highlight ? "bg-ocean-light/[0.06] border border-ocean-light/20" : "bg-dark border border-white/5"
                ]}>
                  <p class="text-[10px] uppercase tracking-wider text-white/30 mb-1">{c.name}</p>
                  <p class="text-sm text-white/70">{(c as any)[row.key]}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Desktop: table -->
      <div class="hidden lg:block overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr>
              <th class="text-left py-4 px-4 text-xs uppercase tracking-wider text-white/30 font-light w-40"></th>
              {competitors.map((c) => (
                <th class:list={[
                  "text-left py-4 px-4",
                  c.highlight && "bg-ocean-light/[0.04] rounded-t-xl"
                ]}>
                  <p class="text-base font-semibold text-white">{c.name}</p>
                  <p class="text-[10px] uppercase tracking-wider text-white/30 font-normal mt-0.5">Est. {c.founded}</p>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row, i) => (
              <tr class={i % 2 === 0 ? "bg-dark/50" : ""}>
                <td class="py-3.5 px-4 text-xs uppercase tracking-wider text-ocean-light/50 font-light align-top whitespace-nowrap">{row.label}</td>
                {competitors.map((c) => (
                  <td class:list={[
                    "py-3.5 px-4 text-white/60 align-top",
                    c.highlight && "bg-ocean-light/[0.04]"
                  ]}>
                    {(c as any)[row.key]}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Pull Quote Breather -->
  <section class="py-16 sm:py-24 bg-dark relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-ocean-light/[0.02] via-transparent to-ocean-light/[0.02]"></div>
    <div class="relative max-w-3xl mx-auto px-6 sm:px-12 lg:px-20 text-center">
      <svg class="w-10 h-10 mx-auto mb-6 text-ocean-light/20" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
      <p class="text-2xl sm:text-3xl font-light text-white/70 leading-relaxed italic">The best surf camp isn't the cheapest one or the biggest one — it's the one where you actually <span class="text-ocean-light font-normal not-italic">improve your surfing</span> and <span class="text-ocean-light font-normal not-italic">make real friends</span>.</p>
    </div>
  </section>

  <!-- What Makes Each Camp Unique -->
  <section class="py-20 sm:py-28 bg-dark-lighter">
    <div class="max-w-6xl mx-auto px-6 sm:px-12 lg:px-20">
      <div class="text-center mb-14">
        <p class="text-xs uppercase tracking-[0.25em] text-ocean-light/60 font-light mb-4">Standout Features</p>
        <h2 class="text-3xl sm:text-4xl font-semibold text-white">What Sets Each Camp Apart</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {competitors.map((c) => (
          <div class:list={[
            "rounded-xl p-6 sm:p-8 transition-colors",
            c.highlight
              ? "bg-ocean-light/[0.06] border-2 border-ocean-light/30"
              : "bg-dark border border-white/5"
          ]}>
            <h3 class="text-lg font-semibold text-white mb-1">{c.name}</h3>
            <p class="text-xs text-white/30 mb-4">{c.tagline}</p>
            <ul class="space-y-2.5">
              {c.unique.map((item) => (
                <li class="flex gap-3 items-start">
                  <span class:list={["mt-0.5 shrink-0 text-sm", c.highlight ? "text-ocean-light" : "text-white/20"]}>&#10003;</span>
                  <span class="text-sm text-white/50">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Deep Dives — each with its own section, icon, and alternating bg -->

  <!-- 1. Surf Coaching -->
  <section class="py-20 sm:py-28 bg-dark">
    <div class="max-w-5xl mx-auto px-6 sm:px-12 lg:px-20">
      <div class="flex items-center gap-4 mb-8">
        <div class="w-12 h-12 rounded-xl bg-ocean-light/10 flex items-center justify-center shrink-0">
          <svg class="w-6 h-6 text-ocean-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>
        </div>
        <div>
          <p class="text-[10px] uppercase tracking-[0.2em] text-ocean-light/40">Deep Dive 01</p>
          <h2 class="text-2xl sm:text-3xl font-semibold text-white">Surf Coaching</h2>
        </div>
      </div>
      <div class="grid md:grid-cols-5 gap-8">
        <div class="md:col-span-3">
          <p class="text-base text-white/60 leading-relaxed mb-6">All-level coaching included in every package with a strict <strong class="text-white/80">max 5:1 student-to-instructor ratio</strong> — one of the lowest in the industry. Video analysis and surf theory come standard, not as paid extras. Whether you're catching your first wave or refining your cutback, coaching is built into the price.</p>
          <div class="flex items-center gap-6 py-5 px-6 bg-ocean-light/[0.06] rounded-xl border border-ocean-light/15">
            <div class="text-center">
              <p class="text-4xl font-bold text-ocean-light leading-none">5:1</p>
              <p class="text-[9px] uppercase tracking-wider text-ocean-light/50 mt-1">Rapture</p>
            </div>
            <div class="w-px h-10 bg-white/10"></div>
            <div class="text-center">
              <p class="text-4xl font-bold text-white/20 leading-none">6:1</p>
              <p class="text-[9px] uppercase tracking-wider text-white/20 mt-1">Kima</p>
            </div>
            <div class="w-px h-10 bg-white/10"></div>
            <div class="text-center">
              <p class="text-4xl font-bold text-white/20 leading-none">8:1</p>
              <p class="text-[9px] uppercase tracking-wider text-white/20 mt-1">Dreamsea</p>
            </div>
            <div class="w-px h-10 bg-white/10"></div>
            <div class="text-center">
              <p class="text-4xl font-bold text-white/20 leading-none">~8:1</p>
              <p class="text-[9px] uppercase tracking-wider text-white/20 mt-1">Lapoint</p>
            </div>
          </div>
        </div>
        <div class="md:col-span-2 space-y-3">
          <p class="text-[10px] uppercase tracking-wider text-white/25 mb-1">Where they shine</p>
          <div class="border-l-2 border-white/10 pl-4 py-2">
            <p class="text-xs font-medium text-white/50">Kima Surf</p>
            <p class="text-xs text-white/30 mt-0.5">14 guided sessions/week. Best for experienced surfers wanting someone to show them the best spots.</p>
          </div>
          <div class="border-l-2 border-white/10 pl-4 py-2">
            <p class="text-xs font-medium text-white/50">Lapoint</p>
            <p class="text-xs text-white/30 mt-0.5">1:1 private coaching, longboarding course, and intensive 2x-daily option.</p>
          </div>
          <div class="border-l-2 border-white/10 pl-4 py-2">
            <p class="text-xs font-medium text-white/50">Dreamsea</p>
            <p class="text-xs text-white/30 mt-0.5">Surfskate integration and PE-designed curriculum. 1:4 ratio at Bali location.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Food & Meals -->
  <section class="py-20 sm:py-28 bg-dark-lighter">
    <div class="max-w-5xl mx-auto px-6 sm:px-12 lg:px-20">
      <div class="flex items-center gap-4 mb-8">
        <div class="w-12 h-12 rounded-xl bg-ocean-light/10 flex items-center justify-center shrink-0">
          <svg class="w-6 h-6 text-ocean-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <div>
          <p class="text-[10px] uppercase tracking-[0.2em] text-ocean-light/40">Deep Dive 02</p>
          <h2 class="text-2xl sm:text-3xl font-semibold text-white">Food & Meals</h2>
        </div>
      </div>
      <div class="grid md:grid-cols-4 gap-4">
        {[
          { name: "Rapture", breakfast: true, dinner: true, note: "3-course breakfast + dinner Mon–Fri, all diets", hl: true },
          { name: "Dreamsea", breakfast: true, dinner: false, note: "Full board in Europe; breakfast-only in Bali", hl: false },
          { name: "Kima Surf", breakfast: true, dinner: false, note: "3-course breakfast included; dinner on your own", hl: false },
          { name: "Lapoint", breakfast: true, dinner: false, note: "Breakfast included; dinner varies by camp", hl: false },
        ].map((m) => (
          <div class:list={[
            "rounded-xl p-5 text-center",
            m.hl ? "bg-ocean-light/[0.08] border-2 border-ocean-light/25" : "bg-dark border border-white/5"
          ]}>
            <p class:list={["text-sm font-semibold mb-4", m.hl ? "text-ocean-light" : "text-white/60"]}>{m.name}</p>
            <div class="flex justify-center gap-6 mb-4">
              <div>
                <div class:list={["w-10 h-10 rounded-full flex items-center justify-center mx-auto mb-1", m.breakfast ? "bg-emerald-500/20" : "bg-white/5"]}>
                  {m.breakfast ? <span class="text-emerald-400 text-lg">&#10003;</span> : <span class="text-white/15 text-lg">&times;</span>}
                </div>
                <p class="text-[9px] uppercase tracking-wider text-white/25">Breakfast</p>
              </div>
              <div>
